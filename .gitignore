# --- Go build artifacts ---
# Compiled binaries from `go build ./cmd/...` with no extension at repo root
# or inside cmd/*/ - these are what caused analytics and generator to get
# committed. Add any other cmd/ binary names here if they show up.
/analytics
/engine
/generator
/cmd/analytics/analytics
/cmd/engine/engine
/cmd/generator/generator
*.exe
*.test
*.out

# Go workspace / vendor (not used here, but harmless to exclude preemptively)
/vendor/

# --- Node / frontend ---
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment / secrets ---
.env
.env.local
.env.*.local
*.pem

# --- Editor / OS noise ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Docker ---
# nothing needed here, docker-compose.yml itself should stay tracked

# --- Logs ---
*.log