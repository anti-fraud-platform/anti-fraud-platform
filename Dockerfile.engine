# пока один общий go module, собираем только engine
FROM golang:1.26-alpine AS build

WORKDIR /app

COPY go.* ./
RUN go mod download

COPY cmd ./cmd

RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/engine ./cmd/engine

FROM alpine:3.21

RUN adduser -D -H appuser
COPY --from=build /bin/engine /usr/local/bin/engine
USER appuser

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/engine"]
